---
const navLinks = [
  { id: 'home',     label: 'Home' },
  { id: 'about',    label: 'About' },
  { id: 'skills',   label: 'Skills' },
  { id: 'projects', label: 'Projects' },
  { id: 'contact',  label: 'Contact' },
];
---

<nav id="navbar" class="backdrop-blur-sm fixed w-full z-50 shadow-lg top-0" style="background: rgba(23, 19, 15, 0.9);">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center">
    <span class="text-xl font-bold select-none" style="color: #c2593a;">TR.</span>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden focus:outline-none transition-colors"
      style="color: #a89b82;"
      onmouseover="this.style.color='#c2593a';"
      onmouseout="this.style.color='#a89b82';"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Nav links -->
    <div
      id="nav-menu"
      class="hidden md:flex absolute md:static top-full left-0 w-full md:w-auto md:bg-transparent shadow-lg md:shadow-none py-4 md:py-0"
      style="background: #17130f;"
    >
      <div class="flex flex-col md:flex-row md:space-x-6 space-y-1 md:space-y-0 px-4 md:px-0 items-end">
        {navLinks.map(link => (
          <button
            data-target={link.id}
            class="nav-link transition-colors duration-200 font-medium text-sm tracking-wide py-2 md:py-0"
            style="color: #a89b82;"
            onmouseover="this.style.color='#c2593a';"
            onmouseout="this.style.color='#a89b82';"
          >
            {link.label}
          </button>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('nav-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  document.addEventListener('click', (e) => {
    const nav = document.getElementById('navbar');
    if (nav && !nav.contains(e.target as Node)) closeMenu();
  });

  function scrollToSection(id: string) {
    document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
    closeMenu();
  }

  document.querySelectorAll<HTMLButtonElement>('.nav-link').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      if (target) scrollToSection(target);
    });
  });
</script>
