---
---

<section id="contact" class="py-20 px-4 bg-gray-900 text-gray-100 relative">
  <!-- Background glows -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-cyan-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto max-w-2xl relative animate-on-scroll">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Get In Touch
        <span class="block w-16 h-1 bg-purple-500 mx-auto mt-3 rounded-full"></span>
      </h2>
      <p class="mt-4 text-lg text-gray-300">
        Have a question or want to work together? Feel free to reach out!
      </p>
    </div>

    <form
      id="contact-form"
      class="bg-gray-800 p-8 rounded-lg shadow-xl border border-gray-700"
      novalidate
    >
      <div class="mb-6">
        <label for="name" class="block text-gray-300 text-sm font-bold mb-2">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Your Name"
          required
          class="w-full border border-gray-600 rounded-lg py-3 px-4 text-gray-100 bg-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 transition-colors duration-200 placeholder-gray-500"
        />
      </div>

      <div class="mb-6">
        <label for="email" class="block text-gray-300 text-sm font-bold mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="your.email@example.com"
          required
          class="w-full border border-gray-600 rounded-lg py-3 px-4 text-gray-100 bg-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 transition-colors duration-200 placeholder-gray-500"
        />
      </div>

      <div class="mb-8">
        <label for="message" class="block text-gray-300 text-sm font-bold mb-2">Message</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          placeholder="Your message here..."
          required
          class="w-full border border-gray-600 rounded-lg py-3 px-4 text-gray-100 bg-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 transition-colors duration-200 resize-y placeholder-gray-500"
        ></textarea>
      </div>

      <div class="flex items-center justify-between gap-4 flex-wrap">
        <button
          id="submit-btn"
          type="submit"
          class="bg-purple-600 hover:bg-purple-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold py-3 px-6 rounded-full hover:scale-105 transition-all duration-300"
        >
          Send Message
        </button>
        <p id="form-status" class="text-sm font-semibold hidden"></p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name    = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email   = (document.getElementById('email') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.className = 'text-sm font-semibold hidden';

    try {
      const res = await fetch('https://formsubmit.co/ajax/tryraisins@gmail.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          name,
          email,
          message,
          _subject: 'New message from your portfolio',
          _template: 'table',
          _captcha: 'false',
        }),
      });

      if (res.ok) {
        status.textContent = 'Message sent successfully!';
        status.className = 'text-sm font-semibold text-green-400';
        form.reset();
      } else {
        throw new Error('Server error');
      }
    } catch {
      status.textContent = 'Failed to send. Please try again.';
      status.className = 'text-sm font-semibold text-red-400';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
