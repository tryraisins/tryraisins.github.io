---
const year = new Date().getFullYear();
---

<footer class="py-10 px-4 text-center" style="background: #0f0c09; color: #857762;">
  <div class="container mx-auto">
    <div class="flex justify-center space-x-6 mb-6">
      <!-- GitHub -->
      <a
        href="https://github.com/tryraisins"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub Profile"
        class="transition-colors duration-300"
        style="color: #857762;"
        onmouseover="this.style.color='#c2593a';"
        onmouseout="this.style.color='#857762';"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/seun-sowemimo-8518b7249/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn Profile"
        class="transition-colors duration-300"
        style="color: #857762;"
        onmouseover="this.style.color='#d97742';"
        onmouseout="this.style.color='#857762';"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>

      <!-- Medium -->
      <a
        href="https://medium.com/@TryRaisins"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Medium Profile"
        class="transition-colors duration-300"
        style="color: #857762;"
        onmouseover="this.style.color='#d9a55c';"
        onmouseout="this.style.color='#857762';"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
        </svg>
      </a>
    </div>

    <p class="text-sm">&copy; {year} TryRaisins. All rights reserved.</p>
    <p class="text-xs mt-2">Built with Astro and Tailwind CSS.</p>
  </div>
</footer>
