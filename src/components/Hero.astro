---
---

<section
  id="home"
  class="relative h-screen flex items-center justify-center text-white overflow-hidden"
  style="background: linear-gradient(135deg, #111828 0%, #202938 100%);"
>
  <!-- Animated grid overlay -->
  <div class="absolute inset-0 opacity-15">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-400/8 to-transparent animate-slide-right"></div>
    <div class="grid-pattern"></div>
  </div>

  <!-- Floating geometric shapes -->
  <div class="absolute top-20 left-10 w-20 h-20 border-2 border-purple-400/20 rotate-45 animate-float"></div>
  <div class="absolute top-40 right-20 w-16 h-16 bg-gradient-to-br from-blue-400/15 to-purple-400/15 animate-float-delayed"></div>
  <div class="absolute bottom-32 left-1/4 w-12 h-12 border border-purple-300/25 rounded-full animate-pulse"></div>
  <div class="absolute bottom-20 right-1/3 w-8 h-20 bg-gradient-to-t from-purple-400/20 to-transparent animate-float-slow"></div>

  <!-- Subtle light rays -->
  <div class="absolute top-0 left-1/2 w-1 h-32 bg-gradient-to-b from-purple-400/30 to-transparent animate-pulse"></div>
  <div class="absolute top-20 right-1/4 w-1 h-24 bg-gradient-to-b from-blue-400/25 to-transparent animate-pulse" style="animation-delay: 1s;"></div>

  <!-- Hero content -->
  <div class="text-center z-10 p-4 animate-fade-in-up">
    <p class="text-xl md:text-2xl text-gray-300 mb-4">Hello, I'm</p>
    <h1 class="text-5xl md:text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-500 mb-6 leading-tight">
      Seun Sowemimo
    </h1>
    <p class="text-2xl md:text-3xl text-gray-400 mb-8">A Fullstack Web Developer</p>
    <a
      href="#projects"
      onclick="event.preventDefault(); document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });"
      class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-8 rounded-full shadow-lg hover:scale-105 transition-all duration-300 hover:shadow-purple-500/25 hover:shadow-xl"
    >
      View My Work
    </a>
  </div>
</section>
