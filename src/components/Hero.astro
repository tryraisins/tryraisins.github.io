---
const nameChars = 'Seun Sowemimo'.split('');
---

<section
  id="home"
  class="relative h-screen flex items-center justify-center overflow-hidden"
  style="background: #17130f; color: #f0e2c9;"
>
  <!-- Animated grid overlay -->
  <div class="absolute inset-0 opacity-15">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-amber-200/5 to-transparent animate-slide-right"></div>
    <div class="grid-pattern"></div>
  </div>

  <!-- Floating geometric shapes -->
  <div class="absolute top-20 left-10 w-20 h-20 border border-amber-200/15 rotate-45 animate-float"></div>
  <div class="absolute top-40 right-20 w-16 h-16 border border-amber-100/10 animate-float-delayed"></div>
  <div class="absolute bottom-32 left-1/4 w-12 h-12 border border-amber-100/15 rounded-full animate-pulse"></div>
  <div class="absolute bottom-20 right-1/3 w-8 h-20 bg-gradient-to-t from-amber-200/10 to-transparent animate-float-slow"></div>

  <!-- Subtle light rays -->
  <div class="absolute top-0 left-1/2 w-px h-32 bg-gradient-to-b from-amber-200/25 to-transparent animate-pulse"></div>
  <div class="absolute top-20 right-1/4 w-px h-24 bg-gradient-to-b from-amber-100/20 to-transparent animate-pulse" style="animation-delay: 1s;"></div>

  <!-- Hero content -->
  <div class="text-center z-10 p-4 animate-fade-in-up">
    <p class="text-xl md:text-2xl mb-4" style="color: #a89b82;">Hello, I'm</p>
    <h1 id="hero-name" class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight select-none" style="color: #f5ead5; letter-spacing: -0.03em;">
      {nameChars.map((ch, i) => (
        ch === ' '
          ? <span class="inline-block" style={`width: 0.4em;`}>&nbsp;</span>
          : <span
              class="hero-letter inline-block"
              style={`animation-delay: ${0.35 + i * 0.07}s;`}
              data-index={i}
            >{ch}</span>
      ))}
    </h1>
    <p class="text-2xl md:text-3xl mb-8" style="color: #8a7d68;">A Fullstack Web Developer</p>
    <a
      href="#projects"
      onclick="event.preventDefault(); document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });"
      class="inline-block font-bold py-3 px-8 rounded-full shadow-lg hover:scale-105 transition-all duration-300 hover:shadow-xl"
      style="background: #c2593a; color: #f5ead5;"
      onmouseover="this.style.background='#a8482d';"
      onmouseout="this.style.background='#c2593a';"
    >
      View My Work
    </a>
  </div>
</section>

<style>
  @keyframes letterReveal {
    0% {
      opacity: 0;
      transform: translateY(50px) rotate(-12deg) scale(0.7);
      filter: blur(10px);
    }
    60% {
      opacity: 1;
      transform: translateY(-6px) rotate(2deg) scale(1.04);
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: translateY(0) rotate(0) scale(1);
      filter: blur(0);
    }
  }

  .hero-letter {
    opacity: 0;
    animation: letterReveal 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.25s ease, text-shadow 0.3s ease;
    transform-origin: center bottom;
    cursor: default;
    position: relative;
  }

  .hero-letter:hover {
    color: #e8a072;
    transform: translateY(-14px) rotate(-6deg) scale(1.18);
    text-shadow: 0 6px 24px rgba(232, 160, 114, 0.45);
  }

  /* Adjacent-letter subtle lean when neighbor hovered */
  .hero-letter:hover + .hero-letter {
    transform: translateY(-4px) rotate(3deg);
    color: #e8c88a;
  }
  .hero-letter:has(+ .hero-letter:hover) {
    transform: translateY(-4px) rotate(-3deg);
    color: #e8c88a;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-letter {
      animation: none;
      opacity: 1;
    }
    .hero-letter:hover {
      transform: none;
    }
  }
</style>
