---
---

<style is:global>
  /* ============================================================
     Shared target styles
     ============================================================ */
  .game-target {
    color: #c2593a !important;
    text-shadow: 0 0 12px rgba(194, 89, 58, 0.7), 0 0 22px rgba(194, 89, 58, 0.35);
    animation: gameTargetPulse 1.1s ease-in-out infinite;
    cursor: pointer;
    display: inline-block;
    position: relative;
    z-index: 5;
    transition: transform 0.15s ease;
  }
  .game-target:hover { transform: scale(1.5) rotate(-6deg); }
  .game-target-hit {
    color: #d9a55c !important;
    text-shadow: 0 0 20px rgba(217, 165, 92, 0.9);
    animation: gameHit 0.5s ease-out forwards;
  }

  .game-word-target {
    color: #c2593a !important;
    background: rgba(194, 89, 58, 0.14);
    border-bottom: 2px solid #c2593a;
    border-radius: 3px;
    padding: 0 3px;
    cursor: pointer;
    text-shadow: 0 0 10px rgba(194, 89, 58, 0.5);
    transition: all 0.2s ease;
    animation: gameTargetPulse 1.4s ease-in-out infinite;
    display: inline-block;
  }
  .game-word-target:hover {
    background: rgba(194, 89, 58, 0.28);
    transform: scale(1.05);
  }
  .game-word-correct {
    color: #d9a55c !important;
    background: rgba(217, 165, 92, 0.25) !important;
    border-bottom-color: #d9a55c !important;
    animation: gameHit 0.5s ease-out forwards;
  }

  .game-seq-letter {
    color: #c2593a !important;
    background: rgba(194, 89, 58, 0.12);
    border-radius: 4px;
    padding: 0 4px;
    cursor: pointer;
    display: inline-block;
    transition: all 0.2s ease;
    position: relative;
    z-index: 5;
  }
  .game-seq-letter.flash {
    background: #c2593a;
    color: #f5ead5 !important;
    transform: scale(1.35);
    text-shadow: 0 0 20px rgba(194, 89, 58, 0.95);
  }
  .game-seq-letter.correct {
    background: rgba(217, 165, 92, 0.45);
    color: #d9a55c !important;
    transform: scale(1.1);
  }
  .game-seq-letter.wrong {
    background: rgba(220, 70, 60, 0.5);
    color: #ffe0d0 !important;
    animation: gameSeqShake 0.4s ease-in-out;
  }

  /* ============================================================
     Keyframes
     ============================================================ */
  @keyframes gameTargetPulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.28); }
  }
  @keyframes gamePulseFast {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.18); }
  }
  @keyframes gameHit {
    0%   { transform: scale(1.5) rotate(-6deg); opacity: 1; }
    100% { transform: scale(2.2) rotate(12deg) translateY(-20px); opacity: 0; }
  }
  @keyframes gameSeqShake {
    0%,100% { transform: translateX(0); }
    25%     { transform: translateX(-4px); }
    75%     { transform: translateX(4px); }
  }

  /* ============================================================
     Chip — prominent, animated, attention-grabbing
     ============================================================ */
  .game-chip {
    position: absolute;
    top: 5rem;
    right: 1.25rem;
    z-index: 55;
    background: rgba(23, 19, 15, 0.94);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(194, 89, 58, 0.5);
    color: #f0e2c9;
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    padding: 10px 14px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: calc(100vw - 2.5rem);
    opacity: 0;
    transform: translateY(-10px) scale(0.85);
    animation: chipEnter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.9s forwards;
    box-shadow: 0 8px 28px rgba(194, 89, 58, 0.28), 0 2px 10px rgba(0,0,0,0.45);
  }
  .game-chip.attention {
    animation: chipEnter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.9s forwards, chipWobble 0.9s ease-in-out 1.7s;
  }
  .game-chip.re-attention {
    animation: chipWobble 0.9s ease-in-out;
  }
  .game-chip-icon {
    font-size: 15px;
    animation: gameIconBob 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  .game-chip-info {
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .game-chip-label { color: #f0e2c9; font-weight: 500; }
  .game-chip-score { font-weight: 700; color: #d9a55c; }
  .game-chip-word {
    font-weight: 700;
    color: #d9a55c;
    background: rgba(217, 165, 92, 0.14);
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 11px;
  }
  .game-chip-btn {
    background: #c2593a;
    color: #f5ead5;
    border: 0;
    border-radius: 999px;
    padding: 5px 12px;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .game-chip-btn:hover { background: #a8482d; transform: scale(1.04); }
  .game-chip-close {
    color: #857762;
    cursor: pointer;
    transition: color 0.2s;
    font-size: 18px;
    line-height: 1;
    padding: 0 2px;
    flex-shrink: 0;
  }
  .game-chip-close:hover { color: #c2593a; }

  .game-arcade {
    position: absolute;
    top: 8.25rem;
    right: 1.25rem;
    z-index: 54;
    width: min(520px, calc(100vw - 2.5rem));
    aspect-ratio: 16 / 10;
    border-radius: 12px;
    border: 1px solid rgba(217, 165, 92, 0.38);
    background: rgba(14, 11, 8, 0.78);
    box-shadow: 0 16px 40px rgba(0,0,0,0.44), 0 0 0 1px rgba(240, 226, 201, 0.04) inset;
    backdrop-filter: blur(8px);
    overflow: hidden;
  }
  .game-arcade canvas {
    display: block;
    width: 100%;
    height: 100%;
    cursor: crosshair;
  }

  @keyframes chipEnter {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes introEnter {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes chipWobble {
    0%, 100% { transform: translateY(0) scale(1) rotate(0); }
    15%      { transform: translateY(-6px) scale(1.12) rotate(-4deg); }
    30%      { transform: translateY(0)    scale(1.06) rotate(4deg); }
    45%      { transform: translateY(-3px) scale(1.04) rotate(-2deg); }
    65%      { transform: translateY(0)    scale(1.02) rotate(1deg); }
  }
  @keyframes gameIconBob {
    0%,100% { transform: translateY(0) rotate(0); }
    25%     { transform: translateY(-2px) rotate(-8deg); }
    75%     { transform: translateY(-1px) rotate(8deg); }
  }

  /* ============================================================
     Section highlight (side bar + radial glow)
     ============================================================ */
  .game-active-section {
    position: relative;
  }
  .game-active-section > .game-glow {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--game-x, 50%) var(--game-y, 50%), rgba(194, 89, 58, 0.08), transparent 45%);
    pointer-events: none;
    transition: background 0.5s ease;
    z-index: 1;
  }
  .game-active-section > .game-bar {
    position: absolute;
    left: 0;
    top: 12%;
    bottom: 12%;
    width: 3px;
    background: linear-gradient(180deg, transparent, #c2593a 20%, #d9a55c 50%, #c2593a 80%, transparent);
    box-shadow: 0 0 14px rgba(194, 89, 58, 0.7);
    animation: sectionBarPulse 2.5s ease-in-out infinite;
    z-index: 5;
    border-radius: 0 3px 3px 0;
  }
  @keyframes sectionBarPulse {
    0%,100% { opacity: 0.55; transform: scaleY(1); }
    50%     { opacity: 1;    transform: scaleY(1.06); }
  }

  /* ============================================================
     Floating game-nav pill (only after the surprise is discovered)
     ============================================================ */
  .game-nav {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    background: rgba(23, 19, 15, 0.94);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(194, 89, 58, 0.55);
    color: #f0e2c9;
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 12px;
    padding: 10px 16px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    box-shadow: 0 10px 36px rgba(194, 89, 58, 0.32), 0 2px 10px rgba(0,0,0,0.5);
    transform: translateY(90px);
    opacity: 0;
    animation: navSlideIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.4s forwards;
    transition: opacity 0.35s ease, background 0.25s, border-color 0.25s, transform 0.2s;
    user-select: none;
  }
  .game-nav:hover {
    background: rgba(31, 25, 18, 1);
    border-color: #d9a55c;
    transform: translateY(-3px);
  }
  .game-nav.dimmed {
    opacity: 0.35;
  }
  .game-nav.dimmed:hover {
    opacity: 1;
  }
  .game-nav-icon {
    font-size: 16px;
    animation: gameIconBob 2s ease-in-out infinite;
  }
  .game-nav-section {
    color: #d9a55c;
    font-weight: 700;
    text-transform: capitalize;
  }

  @keyframes navSlideIn {
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 640px) {
    .game-chip {
      top: 4.5rem;
      right: 0.6rem;
      font-size: 10px;
      padding: 7px 11px;
      gap: 6px;
    }
    .game-chip-icon { font-size: 12px; }
    .game-arcade {
      top: 7.5rem;
      right: 0.6rem;
      width: calc(100vw - 1.2rem);
    }
    .game-nav {
      right: 0.6rem;
      bottom: 0.6rem;
      font-size: 10px;
      padding: 8px 12px;
    }
  }

  /* ============================================================
     Intro card — first thing user sees, explains the game
     ============================================================ */
  .game-intro {
    position: fixed;
    top: 5rem;
    right: 1.25rem;
    z-index: 55;
    background: rgba(23, 19, 15, 0.9);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(217, 165, 92, 0.42);
    color: #f0e2c9;
    font-family: ui-monospace, 'Menlo', monospace;
    padding: 14px 16px 12px;
    border-radius: 12px;
    width: 320px;
    max-width: calc(100vw - 2.5rem);
    box-shadow: 0 14px 34px rgba(0,0,0,0.42), 0 0 0 1px rgba(240, 226, 201, 0.04) inset;
    opacity: 1;
    transform: translateY(0);
    animation: introEnter 0.55s ease both;
  }
  .game-intro.re-attention {
    animation: chipWobble 0.9s ease-in-out;
  }
  .game-intro-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d9a55c;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .game-intro-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d9a55c;
    box-shadow: 0 0 8px rgba(217, 165, 92, 0.8);
  }
  .game-intro-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .game-intro-icon {
    font-size: 20px;
    line-height: 1;
  }
  .game-intro-name {
    font-size: 14px;
    font-weight: 700;
    color: #f5ead5;
    letter-spacing: 0.02em;
    flex: 1;
    line-height: 1.2;
  }
  .game-intro-details {
    display: grid;
    gap: 7px;
    margin: 10px 0 12px;
    font-family: 'Montserrat', ui-sans-serif, sans-serif;
    font-size: 12px;
    line-height: 1.4;
    color: #d9cbb0;
  }
  .game-intro-detail {
    display: grid;
    gap: 2px;
  }
  .game-intro-detail-label {
    color: #d9a55c;
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .game-intro-section {
    color: #f5ead5;
    font-weight: 700;
    text-transform: capitalize;
  }
  .game-intro-close {
    color: #857762;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 0 4px;
    align-self: flex-start;
    margin-top: -2px;
  }
  .game-intro-close:hover { color: #c2593a; }
  .game-intro-hint {
    font-size: 12px;
    line-height: 1.55;
    color: #d9cbb0;
    margin-bottom: 14px;
    font-family: 'Montserrat', ui-sans-serif, sans-serif;
  }
  .game-intro-hint strong {
    color: #d9a55c;
    font-weight: 700;
  }
  .game-intro-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: space-between;
  }
  .game-intro-start {
    background: #c2593a;
    color: #f5ead5;
    border: 0;
    border-radius: 999px;
    padding: 8px 16px;
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(194, 89, 58, 0.25);
  }
  .game-intro-start:hover {
    background: #a8482d;
    transform: scale(1.04);
    box-shadow: 0 6px 20px rgba(194, 89, 58, 0.55);
  }
  .game-intro-shuffle {
    background: transparent;
    color: #a89b82;
    border: 0;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 0.03em;
    cursor: pointer;
    padding: 6px 8px;
    transition: color 0.2s;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
  }
  .game-intro-shuffle:hover {
    color: #d9a55c;
    text-decoration-color: #d9a55c;
  }

  @media (max-width: 640px) {
    .game-intro {
      top: 4.5rem;
      right: 0.6rem;
      width: calc(100vw - 1.2rem);
      padding: 14px 16px 12px;
    }
    .game-intro-name { font-size: 14px; }
    .game-intro-hint { font-size: 11px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .game-target,
    .game-word-target,
    .game-chip,
    .game-chip.attention,
    .game-chip.re-attention,
    .game-chip-icon,
    .game-intro,
    .game-intro.re-attention,
    .game-intro-icon,
    .game-intro-badge-dot,
    .game-nav,
    .game-nav-icon,
    .game-active-section > .game-bar,
    .game-active-section > .game-glow { animation: none !important; }
    .game-chip, .game-nav, .game-intro { opacity: 1; transform: none; }
  }
</style>

<script>
  // ============================================================
  // Types
  // ============================================================
  type GameCtx = {
    section: HTMLElement;
    chip: HTMLElement;
    chipInfo: HTMLElement;
    setLabel: (html: string) => void;
    onDismiss: (fn: () => void) => void;
  };

  type GameResult = {
    status: 'won' | 'lost' | 'ended';
    message: string;
  };

  type Game = {
    id: string;
    name: string;
    icon: string;
    hint: string;
    winCondition: string;
    lossCondition: string;
    play: (ctx: GameCtx) => Promise<GameResult>;
    cleanup: () => void;
  };

  // ============================================================
  // Config
  // ============================================================
  const CANDIDATE_SECTIONS = ['skills', 'projects', 'contact'];
  const EXCLUDE_SELECTOR = '.game-chip, .game-nav, .game-target, .game-word-target, .game-seq-letter, script, style, noscript, svg, button';

  // ============================================================
  // Shared helpers
  // ============================================================
  function pickSection(exclude?: string): HTMLElement | null {
    const pool = CANDIDATE_SECTIONS.filter(id => id !== exclude);
    const shuffled = [...pool].sort(() => Math.random() - 0.5);
    for (const id of shuffled) {
      const el = document.getElementById(id) as HTMLElement | null;
      if (el) return el;
    }
    return null;
  }

  function collectTextNodes(root: HTMLElement): Text[] {
    const nodes: Text[] = [];
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent) return NodeFilter.FILTER_REJECT;
        if (parent.closest(EXCLUDE_SELECTOR)) return NodeFilter.FILTER_REJECT;
        const text = node.textContent || '';
        if (!/[a-zA-Z]/.test(text)) return NodeFilter.FILTER_REJECT;
        if (text.trim().length < 2) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      },
    });
    let n: Node | null;
    while ((n = walker.nextNode())) nodes.push(n as Text);
    return nodes;
  }

  function collectWords(section: HTMLElement, minLen = 4, maxLen = 12): { node: Text; start: number; end: number; word: string }[] {
    const out: { node: Text; start: number; end: number; word: string }[] = [];
    const nodes = collectTextNodes(section);
    const re = /[A-Za-z]{2,}/g;
    for (const node of nodes) {
      const text = node.textContent || '';
      let m: RegExpExecArray | null;
      while ((m = re.exec(text))) {
        const w = m[0];
        if (w.length < minLen || w.length > maxLen) continue;
        out.push({ node, start: m.index, end: m.index + w.length, word: w });
      }
    }
    return out;
  }

  function wrapLetterAt(node: Text, idx: number, className: string, ch?: string): HTMLSpanElement | null {
    const text = node.textContent || '';
    if (idx < 0 || idx >= text.length) return null;
    const parent = node.parentNode;
    if (!parent) return null;

    const before = text.slice(0, idx);
    const letter = ch ?? text[idx];
    const after = text.slice(idx + 1);

    const span = document.createElement('span');
    span.className = className;
    span.textContent = letter;

    const afterNode = document.createTextNode(after);
    parent.replaceChild(afterNode, node);
    parent.insertBefore(span, afterNode);
    if (before) parent.insertBefore(document.createTextNode(before), span);

    return span;
  }

  function wrapRangeInNode(node: Text, start: number, end: number, className: string): HTMLSpanElement | null {
    const text = node.textContent || '';
    if (start < 0 || end > text.length || start >= end) return null;
    const parent = node.parentNode;
    if (!parent) return null;

    const before = text.slice(0, start);
    const middle = text.slice(start, end);
    const after = text.slice(end);

    const span = document.createElement('span');
    span.className = className;
    span.textContent = middle;

    const afterNode = document.createTextNode(after);
    parent.replaceChild(afterNode, node);
    parent.insertBefore(span, afterNode);
    if (before) parent.insertBefore(document.createTextNode(before), span);

    return span;
  }

  function unwrapSpan(span: HTMLElement) {
    const parent = span.parentNode;
    if (!parent) return;
    const text = document.createTextNode(span.textContent || '');
    parent.replaceChild(text, span);
    parent.normalize();
  }

  function unwrapAll(selector: string, root: HTMLElement | Document = document) {
    root.querySelectorAll(selector).forEach(el => unwrapSpan(el as HTMLElement));
  }

  function delay(ms: number) { return new Promise<void>(r => setTimeout(r, ms)); }

  // ============================================================
  // GAME 1 — Signal Trace
  // ============================================================
  function makeSignalTrace(): Game {
    const TARGETS = 6;
    let current: HTMLSpanElement | null = null;
    let disposed = false;

    return {
      id: 'signal-trace',
      name: 'Signal Trace',
      icon: '◇',
      hint: 'A quiet signal will pulse on individual letters in this section. Trace each one before moving to the next.',
      winCondition: 'Trace all 6 highlighted signals.',
      lossCondition: 'No timer. You only lose by closing the game before finishing.',
      cleanup() {
        disposed = true;
        if (current && current.isConnected) unwrapSpan(current);
        current = null;
      },
      async play(ctx) {
        return new Promise<GameResult>((resolve) => {
          let score = 0;
          const place = () => {
            if (disposed) return;
            const nodes = collectTextNodes(ctx.section);
            if (!nodes.length) return;
            for (let attempt = 0; attempt < 15; attempt++) {
              const node = nodes[Math.floor(Math.random() * nodes.length)];
              const text = node.textContent || '';
              const indices: number[] = [];
              for (let i = 0; i < text.length; i++) if (/[a-zA-Z]/.test(text[i])) indices.push(i);
              if (!indices.length) continue;
              const idx = indices[Math.floor(Math.random() * indices.length)];
              const span = wrapLetterAt(node, idx, 'game-target');
              if (!span) continue;
              span.setAttribute('role', 'button');
              span.setAttribute('aria-label', `Terracotta letter: ${span.textContent}`);
              span.tabIndex = 0;
              current = span;
              const handleHit = () => {
                span.classList.add('game-target-hit');
                span.style.pointerEvents = 'none';
                score++;
                ctx.setLabel(`trace signals · <span class="game-chip-score">${score}</span>/${TARGETS}`);
                setTimeout(() => unwrapSpan(span), 500);
                if (score >= TARGETS) {
                  current = null;
                  return resolve({ status: 'won', message: 'You won Signal Trace: all 6 signals traced.' });
                }
                setTimeout(place, 320);
              };
              span.addEventListener('click', handleHit);
              span.addEventListener('keydown', (e: KeyboardEvent) => {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handleHit(); }
              });
              return;
            }
          };
          ctx.setLabel(`trace signals · <span class="game-chip-score">0</span>/${TARGETS}`);
          place();
        });
      },
    };
  }

  // ============================================================
  // GAME 2 — Word Scavenger
  // ============================================================
  function makeWordScavenger(): Game {
    const ROUNDS = 5;
    let currentSpan: HTMLSpanElement | null = null;
    let disposed = false;

    return {
      id: 'word-scavenger',
      name: 'Copy Clue',
      icon: '🔍',
      hint: 'The panel will surface a word from this section. Find the matching highlighted word in the portfolio copy and select it.',
      winCondition: 'Find 5 portfolio copy clues.',
      lossCondition: 'No timer. You only lose by closing the game before finishing.',
      cleanup() {
        disposed = true;
        if (currentSpan && currentSpan.isConnected) unwrapSpan(currentSpan);
        unwrapAll('.game-word-target', document);
        currentSpan = null;
      },
      async play(ctx) {
        return new Promise<GameResult>((resolve) => {
          let score = 0;
          const seen = new Set<string>();
          const pickWord = (): { node: Text; start: number; end: number; word: string } | null => {
            const all = collectWords(ctx.section, 4, 11).filter(w => !seen.has(w.word.toLowerCase()));
            if (!all.length) return null;
            return all[Math.floor(Math.random() * all.length)];
          };
          const round = () => {
            if (disposed) return;
            const pick = pickWord();
            if (!pick) return resolve({ status: 'ended', message: `Game ended: only ${score} words were available here.` });
            seen.add(pick.word.toLowerCase());
            const span = wrapRangeInNode(pick.node, pick.start, pick.end, 'game-word-target');
            if (!span) return round();
            span.setAttribute('role', 'button');
            span.setAttribute('aria-label', `Scavenger target: ${pick.word}`);
            span.tabIndex = 0;
            currentSpan = span;
            ctx.setLabel(`find: <span class="game-chip-word">${pick.word}</span> · <span class="game-chip-score">${score}</span>/${ROUNDS}`);
            const hit = () => {
              span.classList.add('game-word-correct');
              span.style.pointerEvents = 'none';
              score++;
              setTimeout(() => { if (span.isConnected) unwrapSpan(span); }, 550);
              if (score >= ROUNDS) return resolve({ status: 'won', message: 'You won Copy Clue: all 5 words found.' });
              setTimeout(round, 400);
            };
            span.addEventListener('click', hit);
            span.addEventListener('keydown', (e: KeyboardEvent) => {
              if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); hit(); }
            });
          };
          round();
        });
      },
    };
  }

  // ============================================================
  // GAME 3 — Pattern Recall
  // ============================================================
  function makeSequenceRecall(): Game {
    const SEQ_LENGTHS = [3, 4, 5]; // three rounds, growing
    let seqSpans: HTMLSpanElement[] = [];
    let disposed = false;
    let pendingClick: ((el: HTMLSpanElement) => void) | null = null;

    return {
      id: 'sequence-recall',
      name: 'Pattern Recall',
      icon: '🧠',
      hint: 'A few letters in this section flash as a pattern. Watch the portfolio text, then repeat the same order.',
      winCondition: 'Repeat all 3 section patterns in order.',
      lossCondition: 'You lose after 3 wrong clicks.',
      cleanup() {
        disposed = true;
        pendingClick = null;
        seqSpans.forEach(s => { if (s.isConnected) unwrapSpan(s); });
        seqSpans = [];
      },
      async play(ctx) {
        // Pick 6 distinct letters from section text and wrap them
        const nodes = collectTextNodes(ctx.section);
        const picks: { node: Text; idx: number }[] = [];
        const used = new Set<string>();
        for (let attempt = 0; attempt < 200 && picks.length < 6; attempt++) {
          const node = nodes[Math.floor(Math.random() * nodes.length)];
          const text = node.textContent || '';
          const i = Math.floor(Math.random() * text.length);
          if (!/[a-zA-Z]/.test(text[i])) continue;
          const key = `${nodes.indexOf(node)}-${i}`;
          if (used.has(key)) continue;
          used.add(key);
          picks.push({ node, idx: i });
        }
        if (picks.length < 3) return { status: 'ended', message: 'Game ended: not enough text for Pattern Recall.' };

        // Wrap each — process nodes in reverse index order to avoid index shifts
        const byNode = new Map<Text, number[]>();
        picks.forEach(p => {
          if (!byNode.has(p.node)) byNode.set(p.node, []);
          byNode.get(p.node)!.push(p.idx);
        });
        const wraps: HTMLSpanElement[] = [];
        for (const [node, idxs] of byNode) {
          idxs.sort((a, b) => b - a); // descending
          const parent = node.parentNode;
          if (!parent) continue;
          const text = node.textContent || '';
          let rest = text;
          // Instead of tricky splitting, just wrap each highest-idx-first
          // Re-fetch the same text node using DOM: after each wrap the text node splits.
          let currentTextNode: Text = node;
          idxs.forEach((idx) => {
            const t = currentTextNode.textContent || '';
            if (idx >= t.length) return;
            const before = t.slice(0, idx);
            const letter = t.slice(idx, idx + 1);
            const after = t.slice(idx + 1);
            const span = document.createElement('span');
            span.className = 'game-seq-letter';
            span.textContent = letter;
            span.tabIndex = 0;
            const afterNode = document.createTextNode(after);
            const parent2 = currentTextNode.parentNode;
            if (!parent2) return;
            parent2.replaceChild(afterNode, currentTextNode);
            parent2.insertBefore(span, afterNode);
            if (before) parent2.insertBefore(document.createTextNode(before), span);
            wraps.push(span);
            // The remaining "before" text node is now what we operate on for the next lower idx.
            // Since idxs is descending, next idx is smaller than current idx, and lives entirely in `before`.
            currentTextNode = parent2.childNodes[Array.from(parent2.childNodes).indexOf(span) - 1] as Text;
            if (!currentTextNode || currentTextNode.nodeType !== 3) return;
          });
        }
        seqSpans = wraps;
        if (seqSpans.length < 3) {
          this.cleanup();
          return { status: 'ended', message: 'Game ended: not enough letters for Pattern Recall.' };
        }

        const flash = async (span: HTMLSpanElement) => {
          span.classList.add('flash');
          await delay(450);
          span.classList.remove('flash');
          await delay(180);
        };

        const attach = () => {
          seqSpans.forEach(s => {
            s.onclick = () => pendingClick?.(s);
            s.onkeydown = (e: KeyboardEvent) => {
              if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pendingClick?.(s); }
            };
          });
        };
        attach();

        let mistakes = 0;
        for (let round = 0; round < SEQ_LENGTHS.length; round++) {
          if (disposed) return { status: 'ended', message: 'Game stopped.' };
          const len = Math.min(SEQ_LENGTHS[round], seqSpans.length);
          // Build a random sequence over available spans
          const seq: HTMLSpanElement[] = [];
          for (let i = 0; i < len; i++) seq.push(seqSpans[Math.floor(Math.random() * seqSpans.length)]);
          ctx.setLabel(`watch · round <span class="game-chip-score">${round + 1}</span>/${SEQ_LENGTHS.length}`);
          await delay(600);
          for (const s of seq) {
            if (disposed) return { status: 'ended', message: 'Game stopped.' };
            await flash(s);
          }
          ctx.setLabel(`repeat the sequence · <span class="game-chip-score">${round + 1}</span>/${SEQ_LENGTHS.length}`);

          let idxIn = 0;
          let ok = false;
          let lost = false;
          await new Promise<void>((res) => {
            pendingClick = (el) => {
              if (disposed) return res();
              const expect = seq[idxIn];
              if (el === expect) {
                el.classList.add('correct');
                setTimeout(() => el.classList.remove('correct'), 260);
                idxIn++;
                if (idxIn >= seq.length) { ok = true; res(); }
              } else {
                mistakes++;
                el.classList.add('wrong');
                setTimeout(() => el.classList.remove('wrong'), 500);
                if (mistakes >= 3) {
                  lost = true;
                  ctx.setLabel(`lost · wrong clicks <span class="game-chip-score">${mistakes}</span>/3`);
                  return res();
                }
                idxIn = 0;
                setTimeout(() => {
                  ctx.setLabel(`nope — watch again · wrong <span class="game-chip-score">${mistakes}</span>/3`);
                  (async () => {
                    await delay(700);
                    for (const s of seq) { if (disposed) return res(); await flash(s); }
                    ctx.setLabel(`repeat the sequence · <span class="game-chip-score">${round + 1}</span>/${SEQ_LENGTHS.length}`);
                  })();
                }, 550);
              }
            };
          });
          pendingClick = null;
          if (lost) return { status: 'lost', message: 'You lost Pattern Recall: 3 wrong clicks.' };
          if (!ok) return { status: 'ended', message: 'Game stopped.' };
        }
        return { status: 'won', message: 'You won Pattern Recall: all 3 patterns matched.' };
      },
    };
  }

  // ============================================================
  // GAME 4 - Section Invaders
  // ============================================================
  function makeSectionInvaders(): Game {
    let disposed = false;
    let arcade: HTMLDivElement | null = null;
    let raf = 0;
    let cleanupInput: (() => void) | null = null;
    const previousRender = (window as any).render_game_to_text;
    const previousAdvance = (window as any).advanceTime;

    return {
      id: 'section-invaders',
      name: 'Section Invaders',
      icon: '⌁',
      hint: 'Letters from this section form an invader grid. Move with A/D or arrow keys and press Space to fire.',
      winCondition: 'Clear every section character before they reach your line.',
      lossCondition: 'You lose if any invader reaches the player line.',
      cleanup() {
        disposed = true;
        cancelAnimationFrame(raf);
        cleanupInput?.();
        arcade?.remove();
        arcade = null;
        (window as any).render_game_to_text = previousRender;
        (window as any).advanceTime = previousAdvance;
      },
      async play(ctx) {
        return new Promise<GameResult>((resolve) => {
          const text = collectTextNodes(ctx.section)
            .map(node => node.textContent || '')
            .join(' ')
            .replace(/[^A-Za-z0-9]/g, '')
            .toUpperCase();
          const letters = (text || 'PORTFOLIO').slice(0, 30).split('');

          arcade = document.createElement('div');
          arcade.className = 'game-arcade';
          const canvas = document.createElement('canvas');
          arcade.appendChild(canvas);
          ctx.section.appendChild(arcade);

          const canvasCtx = canvas.getContext('2d');
          if (!canvasCtx) {
            resolve({ status: 'ended', message: 'Game ended: canvas could not start.' });
            return;
          }

          const keys = new Set<string>();
          const state = {
            mode: 'playing' as 'playing' | 'won' | 'lost',
            width: 520,
            height: 325,
            playerX: 260,
            playerY: 292,
            playerW: 46,
            invaderDir: 1,
            invaderSpeed: 24,
            drop: 14,
            bullet: null as null | { x: number; y: number; vy: number },
            invaders: letters.map((char, idx) => ({
              char,
              x: 60 + (idx % 10) * 42,
              y: 50 + Math.floor(idx / 10) * 34,
              alive: true,
            })),
          };

          const resize = () => {
            const rect = arcade!.getBoundingClientRect();
            const dpr = Math.min(window.devicePixelRatio || 1, 2);
            canvas.width = Math.max(1, Math.floor(rect.width * dpr));
            canvas.height = Math.max(1, Math.floor(rect.height * dpr));
            canvasCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
            state.width = rect.width;
            state.height = rect.height;
            state.playerY = rect.height - 34;
            state.playerX = Math.min(state.playerX, rect.width - 32);
          };
          resize();

          const onKeyDown = (e: KeyboardEvent) => {
            if (['ArrowLeft', 'ArrowRight', 'a', 'A', 'd', 'D', ' '].includes(e.key)) {
              e.preventDefault();
              if (e.key === ' ' && !state.bullet) {
                state.bullet = { x: state.playerX, y: state.playerY - 18, vy: -290 };
              }
              keys.add(e.key.toLowerCase());
            }
          };
          const onKeyUp = (e: KeyboardEvent) => keys.delete(e.key.toLowerCase());
          const onResize = () => resize();
          window.addEventListener('keydown', onKeyDown);
          window.addEventListener('keyup', onKeyUp);
          window.addEventListener('resize', onResize);
          cleanupInput = () => {
            window.removeEventListener('keydown', onKeyDown);
            window.removeEventListener('keyup', onKeyUp);
            window.removeEventListener('resize', onResize);
          };

          const finish = (result: GameResult) => {
            if (state.mode !== 'playing') return;
            state.mode = result.status;
            ctx.setLabel(result.status === 'won' ? 'invaders cleared' : 'section overrun');
            resolve(result);
          };

          const renderState = () => JSON.stringify({
            game: 'Section Invaders',
            coordinateSystem: 'origin top-left, x right, y down',
            mode: state.mode,
            player: { x: Math.round(state.playerX), y: Math.round(state.playerY) },
            bullet: state.bullet ? { x: Math.round(state.bullet.x), y: Math.round(state.bullet.y) } : null,
            invadersAlive: state.invaders.filter(i => i.alive).length,
            invaders: state.invaders.filter(i => i.alive).slice(0, 12).map(i => ({
              char: i.char,
              x: Math.round(i.x),
              y: Math.round(i.y),
            })),
          });
          (window as any).render_game_to_text = renderState;

          const update = (dt: number) => {
            if (disposed || state.mode !== 'playing') return;
            const left = keys.has('arrowleft') || keys.has('a');
            const right = keys.has('arrowright') || keys.has('d');
            if (left) state.playerX -= 185 * dt;
            if (right) state.playerX += 185 * dt;
            state.playerX = Math.max(24, Math.min(state.width - 24, state.playerX));

            if (keys.has(' ') && !state.bullet) {
              state.bullet = { x: state.playerX, y: state.playerY - 18, vy: -290 };
              keys.delete(' ');
            }

            const alive = state.invaders.filter(i => i.alive);
            let shouldDrop = false;
            for (const invader of alive) {
              invader.x += state.invaderDir * state.invaderSpeed * dt;
              if (invader.x > state.width - 28 || invader.x < 28) shouldDrop = true;
            }
            if (shouldDrop) {
              state.invaderDir *= -1;
              alive.forEach(invader => { invader.y += state.drop; });
              state.invaderSpeed += 4;
            }

            if (state.bullet) {
              state.bullet.y += state.bullet.vy * dt;
              if (state.bullet.y < 0) state.bullet = null;
            }

            if (state.bullet) {
              for (const invader of alive) {
                if (Math.abs(state.bullet.x - invader.x) < 16 && Math.abs(state.bullet.y - invader.y) < 16) {
                  invader.alive = false;
                  state.bullet = null;
                  break;
                }
              }
            }

            const remaining = state.invaders.filter(i => i.alive);
            ctx.setLabel(`section invaders · <span class="game-chip-score">${letters.length - remaining.length}</span>/${letters.length}`);
            if (!remaining.length) {
              finish({ status: 'won', message: 'You won Section Invaders: every section character was cleared.' });
            } else if (remaining.some(i => i.y > state.playerY - 28)) {
              finish({ status: 'lost', message: 'You lost Section Invaders: the characters reached your line.' });
            }
          };
          (window as any).advanceTime = (ms: number) => {
            const steps = Math.max(1, Math.round(ms / (1000 / 60)));
            for (let i = 0; i < steps; i++) update(1 / 60);
            draw();
          };

          const draw = () => {
            canvasCtx.clearRect(0, 0, state.width, state.height);
            canvasCtx.fillStyle = 'rgba(14, 11, 8, 0.88)';
            canvasCtx.fillRect(0, 0, state.width, state.height);
            canvasCtx.strokeStyle = 'rgba(217, 165, 92, 0.18)';
            canvasCtx.lineWidth = 1;
            for (let y = 34; y < state.height; y += 34) {
              canvasCtx.beginPath();
              canvasCtx.moveTo(0, y);
              canvasCtx.lineTo(state.width, y);
              canvasCtx.stroke();
            }

            canvasCtx.font = '700 18px ui-monospace, Menlo, monospace';
            canvasCtx.textAlign = 'center';
            canvasCtx.textBaseline = 'middle';
            state.invaders.forEach(invader => {
              if (!invader.alive) return;
              canvasCtx.fillStyle = '#d9a55c';
              canvasCtx.shadowColor = 'rgba(217, 165, 92, 0.55)';
              canvasCtx.shadowBlur = 10;
              canvasCtx.fillText(invader.char, invader.x, invader.y);
            });
            canvasCtx.shadowBlur = 0;

            if (state.bullet) {
              canvasCtx.fillStyle = '#f5ead5';
              canvasCtx.fillRect(state.bullet.x - 1, state.bullet.y - 9, 2, 12);
            }

            canvasCtx.strokeStyle = '#c2593a';
            canvasCtx.fillStyle = 'rgba(194, 89, 58, 0.22)';
            canvasCtx.beginPath();
            canvasCtx.moveTo(state.playerX, state.playerY - 14);
            canvasCtx.lineTo(state.playerX - state.playerW / 2, state.playerY + 12);
            canvasCtx.lineTo(state.playerX + state.playerW / 2, state.playerY + 12);
            canvasCtx.closePath();
            canvasCtx.fill();
            canvasCtx.stroke();

            canvasCtx.fillStyle = 'rgba(240, 226, 201, 0.72)';
            canvasCtx.font = '11px ui-monospace, Menlo, monospace';
            canvasCtx.textAlign = 'left';
            canvasCtx.fillText('A/D or arrows move · Space fires', 14, state.height - 12);
          };

          let last = performance.now();
          const frame = (now: number) => {
            if (disposed) return;
            const dt = Math.min(0.033, (now - last) / 1000);
            last = now;
            update(dt);
            draw();
            if (state.mode === 'playing') raf = requestAnimationFrame(frame);
          };

          ctx.setLabel(`section invaders · <span class="game-chip-score">0</span>/${letters.length}`);
          canvas.tabIndex = 0;
          canvas.focus();
          draw();
          raf = requestAnimationFrame(frame);
        });
      },
    };
  }

  // ============================================================
  // Surprise orchestrator
  // ============================================================
  const GAME_FACTORIES = [makeSignalTrace, makeWordScavenger, makeSequenceRecall, makeSectionInvaders];

  let activeSection: HTMLElement | null = null;
  let activeGame: Game | null = null;
  let activeChip: HTMLElement | null = null;
  let sectionObserver: IntersectionObserver | null = null;

  const gameNav = document.createElement('div');
  gameNav.className = 'game-nav';
  gameNav.setAttribute('role', 'button');
  gameNav.setAttribute('aria-label', 'Jump to mini-game');
  gameNav.tabIndex = 0;

  function updateNav(labelHtml: string) {
    gameNav.innerHTML = labelHtml;
  }

  function scrollToSection(section: HTMLElement) {
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function attachSectionGlow(section: HTMLElement) {
    section.style.position = section.style.position || 'relative';
    section.classList.add('game-active-section');
    if (!section.querySelector(':scope > .game-glow')) {
      const glow = document.createElement('div');
      glow.className = 'game-glow';
      section.insertBefore(glow, section.firstChild);
    }
    if (!section.querySelector(':scope > .game-bar')) {
      const bar = document.createElement('div');
      bar.className = 'game-bar';
      section.insertBefore(bar, section.firstChild);
    }
    section.addEventListener('mousemove', mouseMoveHandler);
  }

  function detachSectionGlow(section: HTMLElement) {
    section.classList.remove('game-active-section');
    section.querySelectorAll(':scope > .game-glow, :scope > .game-bar').forEach(el => el.remove());
    section.removeEventListener('mousemove', mouseMoveHandler);
  }

  function mouseMoveHandler(e: MouseEvent) {
    const el = e.currentTarget as HTMLElement;
    const rect = el.getBoundingClientRect();
    el.style.setProperty('--game-x', `${((e.clientX - rect.left) / rect.width) * 100}%`);
    el.style.setProperty('--game-y', `${((e.clientY - rect.top) / rect.height) * 100}%`);
  }

  function buildChip(section: HTMLElement, game: Game): { chip: HTMLElement; chipInfo: HTMLElement } {
    const chip = document.createElement('div');
    chip.className = 'game-chip';
    chip.innerHTML = `
      <span class="game-chip-icon" aria-hidden="true">${game.icon}</span>
      <span class="game-chip-info"><span class="game-chip-label">${game.name.toLowerCase()}</span></span>
      <span class="game-chip-close" role="button" aria-label="Dismiss game" title="Dismiss">×</span>
    `;
    section.appendChild(chip);
    const chipInfo = chip.querySelector('.game-chip-info') as HTMLElement;
    const closeEl = chip.querySelector('.game-chip-close') as HTMLElement;
    closeEl.addEventListener('click', () => dismissAll());
    return { chip, chipInfo };
  }

  function buildIntro(section: HTMLElement, game: Game): {
    intro: HTMLElement;
    waitForAction: () => Promise<'start' | 'shuffle' | 'dismiss'>;
  } {
    const intro = document.createElement('div');
    intro.className = 'game-intro attention';
    intro.innerHTML = `
      <div class="game-intro-badge">
        <span class="game-intro-badge-dot" aria-hidden="true"></span>
        <span>challenge unlocked</span>
      </div>
      <div class="game-intro-header">
        <span class="game-intro-icon" aria-hidden="true">${game.icon}</span>
        <span class="game-intro-name">${game.name}</span>
        <span class="game-intro-close" role="button" aria-label="Dismiss" title="Dismiss">x</span>
      </div>
      <div class="game-intro-details">
        <div class="game-intro-detail">
          <span class="game-intro-detail-label">Section</span>
          <span class="game-intro-section">${section.id}</span>
        </div>
        <div class="game-intro-detail">
          <span class="game-intro-detail-label">How to play</span>
          <span>${game.hint}</span>
        </div>
        <div class="game-intro-detail">
          <span class="game-intro-detail-label">How to start</span>
          <span>Press Start to play this section's hidden challenge.</span>
        </div>
        <div class="game-intro-detail">
          <span class="game-intro-detail-label">Win</span>
          <span>${game.winCondition}</span>
        </div>
        <div class="game-intro-detail">
          <span class="game-intro-detail-label">Lose</span>
          <span>${game.lossCondition}</span>
        </div>
      </div>
      <div class="game-intro-actions">
        <button class="game-intro-start" type="button">Start</button>
        <button class="game-intro-shuffle" type="button">switch challenge</button>
      </div>
    `;
    section.appendChild(intro);
    const startBtn = intro.querySelector('.game-intro-start') as HTMLButtonElement;
    const shuffleBtn = intro.querySelector('.game-intro-shuffle') as HTMLButtonElement;
    const closeEl = intro.querySelector('.game-intro-close') as HTMLElement;

    return {
      intro,
      waitForAction: () => new Promise((resolve) => {
        startBtn.addEventListener('click', () => resolve('start'), { once: true });
        shuffleBtn.addEventListener('click', () => resolve('shuffle'), { once: true });
        closeEl.addEventListener('click', () => resolve('dismiss'), { once: true });
      }),
    };
  }

  function nudgeIntro(intro: HTMLElement) {
    intro.classList.remove('re-attention');
    void intro.offsetWidth;
    intro.classList.add('re-attention');
  }

  function setChipLabel(chipInfo: HTMLElement, html: string) {
    chipInfo.innerHTML = html;
  }

  function nudgeChip(chip: HTMLElement) {
    chip.classList.remove('re-attention');
    void chip.offsetWidth; // reflow
    chip.classList.add('re-attention');
  }

  function observeSection(section: HTMLElement, primaryEl: HTMLElement) {
    if (sectionObserver) sectionObserver.disconnect();
    let seen = false;
    sectionObserver = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          gameNav.classList.add('dimmed');
          if (!seen) {
            seen = true;
            if (primaryEl.classList.contains('game-intro')) nudgeIntro(primaryEl);
            else nudgeChip(primaryEl);
          }
        } else {
          gameNav.classList.remove('dimmed');
        }
      }
    }, { threshold: 0.25 });
    sectionObserver.observe(section);
  }

  function dismissAll() {
    if (activeGame) activeGame.cleanup();
    if (activeChip && activeChip.parentNode) activeChip.parentNode.removeChild(activeChip);
    if (activeSection) detachSectionGlow(activeSection);
    if (sectionObserver) sectionObserver.disconnect();
    activeGame = null;
    activeChip = null;
    activeSection = null;
    if (gameNav.parentNode) gameNav.parentNode.removeChild(gameNav);
  }

  async function startGame(preferredSectionId?: string, excludeSectionId?: string, excludeGameId?: string) {
    // Cleanup any previous
    if (activeGame) activeGame.cleanup();
    if (activeChip && activeChip.parentNode) activeChip.parentNode.removeChild(activeChip);
    if (activeSection) detachSectionGlow(activeSection);
    if (sectionObserver) sectionObserver.disconnect();

    // Pick section
    let section: HTMLElement | null = null;
    if (preferredSectionId) section = document.getElementById(preferredSectionId);
    if (!section) section = pickSection(excludeSectionId);
    if (!section) return;

    // Pick game (avoid repeating same one back-to-back if possible)
    const pool = GAME_FACTORIES.filter(f => f().id !== excludeGameId);
    const factory = (pool.length ? pool : GAME_FACTORIES)[Math.floor(Math.random() * (pool.length || GAME_FACTORIES.length))];
    const game = factory();

    activeSection = section;
    activeGame = game;

    attachSectionGlow(section);

    // -------- Phase 1: intro card --------
    const { intro, waitForAction } = buildIntro(section, game);
    activeChip = intro; // treated as the section anchor for observers/dismiss

    observeSection(section, intro);

    const action = await waitForAction();
    if (!activeGame || activeGame !== game) return; // dismissed / replaced

    intro.remove();

    if (action === 'dismiss') {
      dismissAll();
      return;
    }
    if (action === 'shuffle') {
      return startGame(section.id, undefined, game.id);
    }
    // -------- Phase 2: play --------
    const { chip, chipInfo } = buildChip(section, game);
    chip.classList.add('re-attention');
    activeChip = chip;

    // Re-observe with new anchor so IntersectionObserver still fires
    observeSection(section, chip);

    // Update nav to reflect active play state
    updateNav(`
      <span class="game-nav-icon" aria-hidden="true">${game.icon}</span>
      <span><span class="game-nav-section">${game.name}</span> playing in ${section.id}</span>
    `);
    if (!gameNav.parentNode) document.body.appendChild(gameNav);
    gameNav.onclick = () => { if (activeSection) scrollToSection(activeSection); };

    const ctx: GameCtx = {
      section,
      chip,
      chipInfo,
      setLabel: (html) => setChipLabel(chipInfo, html),
      onDismiss: () => {},
    };

    let result: GameResult = { status: 'ended', message: 'Game ended.' };
    try {
      result = await game.play(ctx);
    } catch (e) {
      result = { status: 'ended', message: 'Game ended unexpectedly.' };
    }
    if (!activeGame || activeGame !== game) return; // dismissed / replaced mid-play

    game.cleanup();

    // -------- Phase 3: completion — chip becomes "play another" --------
    chip.classList.add('re-attention');
    const resultLabel = result.status === 'won' ? 'Won' : result.status === 'lost' ? 'Lost' : 'Ended';
    const resultIcon = result.status === 'won' ? '✓' : result.status === 'lost' ? '!' : 'i';
    chip.innerHTML = `
      <span class="game-chip-icon" aria-hidden="true">${resultIcon}</span>
      <span class="game-chip-info"><span class="game-chip-score">${resultLabel}</span><span class="game-chip-label">${result.message}</span></span>
      <button class="game-chip-btn" type="button">play another</button>
      <span class="game-chip-close" role="button" aria-label="Dismiss game" title="Dismiss">x</span>
    `;
    const btn = chip.querySelector('.game-chip-btn') as HTMLButtonElement;
    const closeEl = chip.querySelector('.game-chip-close') as HTMLElement;
    btn.addEventListener('click', () => startGame(undefined, section!.id, game.id));
    closeEl.addEventListener('click', () => dismissAll());

    updateNav(`
      <span class="game-nav-icon" aria-hidden="true">${resultIcon}</span>
      <span>${resultLabel}: ${game.name}. Tap to play another.</span>
    `);
    gameNav.classList.remove('dimmed');
    gameNav.onclick = () => startGame(undefined, section!.id, game.id);
    gameNav.onkeydown = (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); startGame(undefined, section!.id, game.id); }
    };
  }

  function boot() {
    const sections = CANDIDATE_SECTIONS
      .map(id => document.getElementById(id) as HTMLElement | null)
      .filter((section): section is HTMLElement => Boolean(section));
    if (!sections.length) return;

    let revealed = false;
    const reveal = (section: HTMLElement, observer?: IntersectionObserver) => {
      if (revealed || activeGame) return;
      revealed = true;
      observer?.disconnect();
      window.removeEventListener('scroll', fallbackCheck);
      window.removeEventListener('resize', fallbackCheck);
      startGame(section.id);
    };

    const sectionInView = (section: HTMLElement) => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      return rect.top < viewportHeight * 0.82 && rect.bottom > viewportHeight * 0.18;
    };

    const fallbackCheck = () => {
      const visible = sections.find(sectionInView);
      if (visible) reveal(visible);
    };

    if (!('IntersectionObserver' in window)) {
      fallbackCheck();
      window.addEventListener('scroll', fallbackCheck, { passive: true });
      window.addEventListener('resize', fallbackCheck);
      return;
    }

    const revealObserver = new IntersectionObserver((entries) => {
      const visible = entries
        .filter(entry => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible?.target instanceof HTMLElement) reveal(visible.target, revealObserver);
    }, {
      rootMargin: '0px 0px -12% 0px',
      threshold: [0.08, 0.18, 0.3],
    });

    sections.forEach(section => revealObserver.observe(section));
    fallbackCheck();
    window.addEventListener('scroll', fallbackCheck, { passive: true });
    window.addEventListener('resize', fallbackCheck);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
