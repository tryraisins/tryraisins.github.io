---
import '../styles/global.css';

const projects = [
  { number: '01', name: 'QuickBillz', type: 'Product / Invoicing', year: '2026', accent: '#ff5c35' },
  { number: '02', name: 'Terror Tracker', type: 'Live intelligence map', year: '2026', accent: '#b8ff32' },
  { number: '03', name: 'Talent Hunter', type: 'Applied NLP', year: '2026', accent: '#74a7ff' },
  { number: '04', name: 'Echo List', type: 'Music utility', year: '2025', accent: '#ffcf40' },
  { number: '05', name: 'BetPicks', type: 'Sports picks product', year: '2026', accent: '#ff78bd', href: 'https://betpicks.tryraisins.dev/' },
];

const games = [
  { key: '01', name: 'Glyph Serpent', note: 'A section-sized snake consumes every visible character. Each glyph becomes a body segment; the copy restores when the run ends.' },
  { key: '02', name: 'Five-ish', note: 'A Wordle-style deduction game generated only from words longer than four letters in the active section.' },
  { key: '03', name: 'Stack Architect', note: 'Build a valid product architecture by connecting drifting frontend, data, API, and deployment nodes under real constraints.' },
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#f0ede4" />
    <title>TryRaisins — Design Concept</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Mono:wght@300;400;500&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>if (location.hash.includes('figmacapture=')) document.documentElement.classList.add('figma-capture');</script>
    <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <canvas class="systems-map" aria-hidden="true"></canvas>
    <div class="cursor-orbit" aria-hidden="true"></div>

    <nav class="nav-shell" aria-label="Concept navigation">
      <a class="brand" href="#top" aria-label="TryRaisins home">
        <span class="brand-dot"></span>
        TRYRAISINS
      </a>
      <div class="nav-links">
        <a href="#work">Work</a>
        <a href="#play">Play</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </div>
      <button class="theme-toggle" type="button" aria-label="Toggle color theme">
        <span class="theme-icon">◐</span>
        <span class="theme-label">Invert</span>
      </button>
    </nav>

    <main id="top">
      <section class="hero section-scene" data-section="hero" data-scheme="paper">
        <svg class="hero-line" viewBox="0 0 1200 720" preserveAspectRatio="none" aria-hidden="true">
          <path d="M-80 490 C120 200 230 705 410 390 S700 90 725 410 S995 720 1280 220" />
          <path class="line-echo" d="M-30 560 C200 370 320 700 510 450 S810 205 840 490 S1080 640 1240 350" />
        </svg>

        <div class="hero-kicker">
          <span>Fullstack developer</span>
          <span>Lagos, NG</span>
          <span>Available for ambitious work</span>
        </div>

        <div class="hero-title" aria-label="Building things that work">
          <div class="title-row"><span>BUILDING</span><i>01</i></div>
          <div class="title-row title-shift"><span>THINGS</span><i>02</i></div>
          <div class="title-row title-outline"><span>THAT WORK.</span><i>03</i></div>
        </div>

        <div class="hero-foot">
          <p>I turn difficult ideas into fast, useful digital products—then hide a little mischief in the details.</p>
          <a class="round-link" href="#work" aria-label="See selected work"><span>↓</span></a>
        </div>
      </section>

      <section class="capabilities section-scene" data-section="capabilities" data-scheme="signal" aria-labelledby="capabilities-title">
        <div class="cap-intro reveal">
          <p class="eyebrow">Capabilities / no empty scrolling</p>
          <h2 id="capabilities-title">ONE BUILDER.<br /><em>FOUR SYSTEMS.</em></h2>
          <p>A compact map of how ideas move from interface to production. Hover a lane to trace the signal.</p>
        </div>
        <div class="cap-grid">
          <article class="cap-card reveal" style="--delay:0ms"><span>01 / Interface</span><h3>Make it felt.</h3><p>React · TypeScript · Motion · Accessibility</p><i>UI</i></article>
          <article class="cap-card reveal" style="--delay:80ms"><span>02 / Systems</span><h3>Make it hold.</h3><p>Node · APIs · Data · Architecture</p><i>API</i></article>
          <article class="cap-card reveal" style="--delay:160ms"><span>03 / Intelligence</span><h3>Make it think.</h3><p>Python · NLP · Automation · Search</p><i>AI</i></article>
          <article class="cap-card reveal" style="--delay:240ms"><span>04 / Delivery</span><h3>Make it real.</h3><p>Cloud · CI/CD · Observability · Scale</p><i>SHIP</i></article>
        </div>
      </section>

      <section id="work" class="work section-scene" data-section="work" data-scheme="warm">
        <header class="section-head reveal">
          <p class="eyebrow">Selected output / 2024—2026</p>
          <h2>WORK THAT<br /><em>EARNS</em> ATTENTION.</h2>
          <p class="head-note">The projects stay central. Motion supports the story; it never buries the proof.</p>
        </header>

        <div class="project-list">
          {projects.map((project) => (
            <a class="project reveal" href={project.href ?? '#'} target={project.href ? '_blank' : undefined} rel={project.href ? 'noopener noreferrer' : undefined} style={`--project-accent:${project.accent}`}>
              <span class="project-number">{project.number}</span>
              <span class="project-name">{project.name}</span>
              <span class="project-meta">{project.type}</span>
              <span class="project-year">{project.year}</span>
              <span class="project-arrow">↗</span>
            </a>
          ))}
        </div>
      </section>

      <section id="play" class="play section-scene" data-section="play" data-scheme="ink">
        <div class="play-intro reveal">
          <p class="eyebrow">The page plays back</p>
          <h2>NOT AN ARCADE.<br />A LIVING <em>PORTFOLIO.</em></h2>
          <p>Games emerge from the section you are reading. The words, skills, and projects are the pieces—not decoration pasted over the work.</p>
        </div>

        <div class="game-stage reveal">
          <div class="stage-topbar">
            <span>Hidden systems / preview</span>
            <span class="stage-status"><i></i> section content detected</span>
          </div>
          <div class="snake-demo" aria-hidden="true">
            <div class="demo-copy">BUILD <span>DIGITAL</span> PRODUCTS WITH PURPOSE</div>
            <div class="snake">
              <i>T</i><i>R</i><i>Y</i><i>R</i><i>•</i><i>•</i><i class="snake-head">›</i>
            </div>
            <div class="food">A</div>
          </div>
          <div class="stage-caption">
            <span>GLYPH SERPENT</span>
            <p>The snake literally grows from the portfolio’s type.</p>
          </div>
        </div>

        <div class="game-list">
          {games.map((game) => (
            <article class="game-card reveal">
              <span class="game-key">{game.key}</span>
              <h3>{game.name}</h3>
              <p>{game.note}</p>
              <span class="game-state">Proposed</span>
            </article>
          ))}
        </div>
      </section>

      <section id="about" class="about section-scene" data-section="about" data-scheme="orange">
        <svg class="about-scribble" viewBox="0 0 1000 500" preserveAspectRatio="none" aria-hidden="true">
          <path d="M-40 180 C90 20 170 390 305 205 C430 35 450 440 590 220 C720 20 775 430 1040 120" />
        </svg>
        <p class="about-index">05 / About the builder</p>
        <p class="about-copy reveal">I’m TryRaisins, a fullstack developer who likes useful systems, strong opinions, and interfaces with a pulse.</p>
      </section>

      <section id="contact" class="contact section-scene" data-section="contact" data-scheme="contact" aria-labelledby="contact-title">
        <div class="contact-topline">
          <p>06 / Start a conversation</p>
          <p>Lagos, Nigeria · Available worldwide</p>
        </div>
        <div class="contact-center reveal">
          <p class="contact-kicker">Have a difficult idea?</p>
          <h2 id="contact-title">LET’S BUILD<br /><em>SOMETHING</em><br />THAT WORKS.</h2>
          <a class="contact-email" href="mailto:tryraisins@gmail.com">tryraisins@gmail.com <span>↗</span></a>
        </div>
        <div class="contact-footer">
          <p>Find TryRaisins elsewhere</p>
          <div class="contact-socials">
            <a href="https://github.com/tryraisins" target="_blank" rel="noopener noreferrer"><span>GitHub</span><i>Code / experiments</i><b>↗</b></a>
            <a href="https://medium.com/@TryRaisins" target="_blank" rel="noopener noreferrer"><span>Medium</span><i>Ideas / writing</i><b>↗</b></a>
          </div>
          <p>© {new Date().getFullYear()} TryRaisins</p>
        </div>
        <div class="contact-orbit" aria-hidden="true"><span>OPEN TO GOOD PROBLEMS · OPEN TO GOOD PEOPLE · </span></div>
      </section>
    </main>

    <button class="game-trigger" type="button" aria-label="Preview hidden game system">
      <span class="trigger-pulse"></span>
      Play this section
      <b>⌁</b>
    </button>

    <div class="concept-note" role="dialog" aria-modal="true" aria-labelledby="concept-title" hidden>
      <button class="concept-close" type="button" aria-label="Close">×</button>
      <span class="concept-tag">Prototype interaction</span>
      <h2 id="concept-title">The game launcher follows context.</h2>
      <p>In the final build, this opens a challenge generated from the section currently in view. It stays optional, compact, and out of the way of hiring managers who only want the work.</p>
      <button class="concept-ok" type="button">Got it</button>
    </div>

    <script>
      const root = document.documentElement;
      const toggle = document.querySelector('.theme-toggle');
      const orbit = document.querySelector('.cursor-orbit');
      const launcher = document.querySelector('.game-trigger');
      const dialog = document.querySelector('.concept-note');
      const closeButtons = dialog?.querySelectorAll('.concept-close, .concept-ok');

      toggle?.addEventListener('click', () => {
        root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
      });

      if (orbit instanceof HTMLElement && matchMedia('(pointer:fine)').matches) {
        let targetX = innerWidth / 2;
        let targetY = innerHeight / 2;
        let x = targetX;
        let y = targetY;
        addEventListener('pointermove', (event) => {
          targetX = event.clientX;
          targetY = event.clientY;
        }, { passive: true });
        const follow = () => {
          x += (targetX - x) * .14;
          y += (targetY - y) * .14;
          orbit.style.transform = `translate3d(${x}px, ${y}px, 0)`;
          requestAnimationFrame(follow);
        };
        follow();
      }

      const mapCanvas = document.querySelector('.systems-map');
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (mapCanvas instanceof HTMLCanvasElement) {
        const context = mapCanvas.getContext('2d');
        const labels = ['UI', 'API', 'DATA', 'SHIP', 'BUILD', 'PLAY', 'IDEA', 'USE'];
        let width = innerWidth;
        let height = innerHeight;
        let pointerX = width * .72;
        let pointerY = height * .35;
        let nodes = [];

        const resizeMap = () => {
          width = innerWidth;
          height = innerHeight;
          const ratio = Math.min(devicePixelRatio || 1, 1.6);
          mapCanvas.width = width * ratio;
          mapCanvas.height = height * ratio;
          mapCanvas.style.width = `${width}px`;
          mapCanvas.style.height = `${height}px`;
          context?.setTransform(ratio, 0, 0, ratio, 0, 0);
          nodes = labels.map((label, index) => ({
            label,
            x: (width / labels.length) * (index + .55),
            y: height * (.2 + ((index * 37) % 58) / 100),
            vx: ((index % 3) - 1) * .055,
            vy: ((index % 2) ? 1 : -1) * .045,
          }));
        };

        const drawMap = () => {
          if (!context) return;
          context.clearRect(0, 0, width, height);
          const ink = getComputedStyle(document.body).color;
          context.strokeStyle = ink;
          context.fillStyle = ink;
          context.globalAlpha = .16;
          context.lineWidth = 1;
          context.setLineDash([3, 8]);
          nodes.forEach((node, index) => {
            const next = nodes[(index + 1) % nodes.length];
            const pullX = (pointerX - node.x) * .00008;
            const pullY = (pointerY - node.y) * .00008;
            if (!reduceMotion) {
              node.x += node.vx + pullX;
              node.y += node.vy + pullY;
              if (node.x < 20 || node.x > width - 20) node.vx *= -1;
              if (node.y < 90 || node.y > height - 40) node.vy *= -1;
            }
            context.beginPath();
            context.moveTo(node.x, node.y);
            context.quadraticCurveTo((node.x + next.x) / 2, pointerY * .18 + height * .28, next.x, next.y);
            context.stroke();
            context.setLineDash([]);
            context.beginPath();
            context.arc(node.x, node.y, index % 2 ? 4 : 7, 0, Math.PI * 2);
            context.stroke();
            context.font = '9px DM Mono';
            context.fillText(node.label, node.x + 11, node.y + 3);
            context.setLineDash([3, 8]);
          });
          context.globalAlpha = 1;
          requestAnimationFrame(drawMap);
        };
        addEventListener('pointermove', (event) => { pointerX = event.clientX; pointerY = event.clientY; }, { passive: true });
        addEventListener('resize', resizeMap, { passive: true });
        resizeMap();
        drawMap();
      }

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: .12 });
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

      let activeSection = '';
      const scenes = [...document.querySelectorAll('.section-scene')];
      const switchScene = (section) => {
        const name = section.dataset.section || 'hero';
        if (name === activeSection) return;
        activeSection = name;
        root.dataset.scene = section.dataset.scheme || 'paper';
        const activeIndex = scenes.indexOf(section);
        scenes.forEach((item, index) => {
          item.classList.toggle('scene-active', item === section);
          item.classList.toggle('scene-before', index < activeIndex);
          item.classList.toggle('scene-after', index > activeIndex);
        });
        launcher?.setAttribute('data-current', name);
      };

      const visibleSections = new Map();
      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => visibleSections.set(entry.target, entry.intersectionRatio));
        const current = [...visibleSections.entries()].sort((a, b) => b[1] - a[1])[0];
        if (current?.[0] instanceof HTMLElement && current[1] > 0) switchScene(current[0]);
      }, { threshold: [0, .15, .35, .55, .75] });
      scenes.forEach((el) => sectionObserver.observe(el));
      const firstScene = document.querySelector('.section-scene');
      if (firstScene instanceof HTMLElement) switchScene(firstScene);

      launcher?.addEventListener('click', () => {
        if (dialog instanceof HTMLElement) dialog.hidden = false;
      });
      closeButtons?.forEach((button) => button.addEventListener('click', () => {
        if (dialog instanceof HTMLElement) dialog.hidden = true;
      }));
    </script>
  </body>
</html>

<style is:global>
  :root {
    --paper: #f0ede4;
    --ink: #11110f;
    --soft-ink: #5d5a52;
    --rule: rgba(17, 17, 15, .22);
    --acid: #b8ff32;
    --orange: #ff5c35;
    --panel: #151513;
    --panel-ink: #f4f0e7;
  }

  [data-theme='dark'] {
    --paper: #11110f;
    --ink: #f0ede4;
    --soft-ink: #aaa69c;
    --rule: rgba(240, 237, 228, .2);
    --panel: #f0ede4;
    --panel-ink: #11110f;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; background: var(--paper); }
  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: 'Manrope', sans-serif;
    overflow-x: hidden;
    transition: background .45s ease, color .45s ease;
  }
  main { position: relative; z-index: 1; }
  a, button { cursor: pointer; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; }

  .grain {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    opacity: .045;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.8'/%3E%3C/svg%3E");
  }

  .systems-map {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: .82;
    transition: opacity .5s ease, filter .5s ease;
  }
  [data-scene='ink'] .systems-map { opacity: .28; filter: invert(1); }
  [data-scene='orange'] .systems-map { opacity: .55; }

  .section-scene {
    position: relative;
    isolation: isolate;
    opacity: 1;
  }

  .cursor-orbit {
    position: fixed;
    width: 38px;
    height: 38px;
    margin: -19px 0 0 -19px;
    border: 1px solid var(--ink);
    border-radius: 50%;
    z-index: 99;
    pointer-events: none;
    mix-blend-mode: difference;
    opacity: .5;
  }

  .nav-shell {
    position: fixed;
    z-index: 90;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: min(820px, calc(100% - 28px));
    height: 52px;
    padding: 6px 8px 6px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: color-mix(in srgb, var(--paper) 78%, transparent);
    backdrop-filter: blur(18px);
    box-shadow: 0 12px 45px rgba(0,0,0,.1);
    font: 500 11px/1 'DM Mono', monospace;
    text-transform: uppercase;
    letter-spacing: .06em;
  }
  .brand { display: flex; align-items: center; gap: 8px; }
  .brand-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--orange); box-shadow: 0 0 0 4px color-mix(in srgb, var(--orange) 18%, transparent); }
  .nav-links { display: flex; gap: clamp(16px, 4vw, 42px); }
  .nav-links a { position: relative; }
  .nav-links a::after { content: ''; position: absolute; left: 0; right: 100%; bottom: -5px; height: 1px; background: var(--ink); transition: right .25s ease; }
  .nav-links a:hover::after { right: 0; }
  .theme-toggle { border: 0; border-radius: 999px; background: var(--ink); color: var(--paper); padding: 10px 14px; display: flex; align-items: center; gap: 7px; text-transform: uppercase; font-size: 10px; letter-spacing: .06em; }

  .hero {
    position: relative;
    min-height: 100svh;
    padding: 100px 4vw 34px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }
  .hero-kicker, .hero-foot { position: relative; z-index: 2; }
  .hero-kicker { display: flex; justify-content: space-between; gap: 20px; font: 400 10px/1 'DM Mono', monospace; letter-spacing: .12em; text-transform: uppercase; }
  .hero-title { position: relative; z-index: 2; padding: 5vh 0 3vh; }
  .title-row { display: flex; align-items: flex-start; gap: 14px; font: 400 clamp(4.4rem, 12.8vw, 12rem)/.77 'Archivo Black', sans-serif; letter-spacing: -.08em; white-space: nowrap; }
  .title-row i { font: 400 9px/1 'DM Mono', monospace; letter-spacing: 0; color: var(--orange); }
  .title-shift { padding-left: 13vw; }
  .title-outline span { color: transparent; -webkit-text-stroke: clamp(1px, .12vw, 2px) var(--ink); }
  .hero-line { position: absolute; z-index: 1; inset: 8% -4% 0; width: 108%; height: 88%; fill: none; stroke: var(--orange); stroke-width: 6; stroke-linecap: round; filter: drop-shadow(0 9px 0 var(--acid)); }
  .hero-line path { stroke-dasharray: 2400; stroke-dashoffset: 2400; animation: drawLine 2.4s cubic-bezier(.22,1,.36,1) .35s forwards; }
  .hero-line .line-echo { stroke: var(--ink); stroke-width: 1.5; filter: none; animation-delay: .65s; }
  .hero-foot { display: flex; align-items: end; justify-content: space-between; }
  .hero-foot p { max-width: 490px; margin: 0; font-size: clamp(1rem, 1.6vw, 1.35rem); line-height: 1.35; }
  .round-link { width: 58px; height: 58px; border: 1px solid var(--ink); border-radius: 50%; display: grid; place-items: center; font-size: 24px; transition: color .25s, background .25s, transform .25s; }
  .round-link:hover { color: var(--paper); background: var(--ink); transform: rotate(-35deg); }

  .capabilities {
    padding: 7vw 4vw 8vw;
    background: var(--acid);
    color: #111;
  }
  .cap-intro { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 30px; align-items: start; margin-bottom: 5vw; }
  .cap-intro h2 { margin: 0; font: 400 clamp(3rem, 7.3vw, 7.4rem)/.87 'Archivo Black', sans-serif; letter-spacing: -.07em; }
  .cap-intro h2 em { color: transparent; -webkit-text-stroke: 1.5px #111; font-style: normal; }
  .cap-intro > p:last-child { margin: 0; font-size: 14px; line-height: 1.55; }
  .cap-grid { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid rgba(17,17,15,.35); }
  .cap-card { position: relative; min-height: 245px; padding: 22px; overflow: hidden; border-right: 1px solid rgba(17,17,15,.35); transition-delay: var(--delay); }
  .cap-card:last-child { border-right: 0; }
  .cap-card::before { content: ''; position: absolute; inset: auto 0 0; height: 7px; background: #111; transform: scaleX(.08); transform-origin: left; transition: transform .55s cubic-bezier(.22,1,.36,1); }
  .cap-card:hover::before { transform: scaleX(1); }
  .cap-card span { font: 500 9px/1 'DM Mono', monospace; text-transform: uppercase; letter-spacing: .1em; }
  .cap-card h3 { margin: 54px 0 16px; font: 400 clamp(1.65rem, 2.7vw, 3rem)/.92 'Archivo Black', sans-serif; letter-spacing: -.055em; }
  .cap-card p { margin: 0; max-width: 220px; font: 400 10px/1.6 'DM Mono', monospace; text-transform: uppercase; }
  .cap-card i { position: absolute; right: 14px; bottom: 10px; color: rgba(17,17,15,.1); font: 400 clamp(3.7rem, 6vw, 7rem)/1 'Archivo Black', sans-serif; letter-spacing: -.1em; font-style: normal; transition: transform .5s ease, color .5s ease; }
  .cap-card:hover i { color: rgba(17,17,15,.22); transform: translateY(-9px) rotate(-4deg); }

  .work { padding: 10vw 4vw 11vw; background: #f0ede4; color: #11110f; }
  .section-head { display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 30px; align-items: start; margin-bottom: 9vw; }
  .eyebrow { font: 500 10px/1.3 'DM Mono', monospace; text-transform: uppercase; letter-spacing: .1em; }
  .section-head h2, .play-intro h2 { margin: 0; font: 400 clamp(3rem, 7.3vw, 7.4rem)/.87 'Archivo Black', sans-serif; letter-spacing: -.07em; }
